# .env.example: environment variables referenced by MNM-Edu.
# Copy this file to .env.local for local development. The real .env and .env.local
# files are gitignored and must never be committed. This example documents the
# variables only and contains no secrets.

# ---------------------------------------------------------------------------
# Used by the app today
# ---------------------------------------------------------------------------

# Node environment. Next.js normally sets this automatically (development under
# `next dev`, production under `next build`). Set it only if you have a reason to.
NODE_ENV=development

# Port for the local static file server (scripts/serve.js, launched by
# "Start MNM-Edu.bat"). Defaults to 3041 when unset.
PORT=3041

# ---------------------------------------------------------------------------
# Database: MySQL/MariaDB connection (Review Console; Stage A, item 8)
# ---------------------------------------------------------------------------
# REQUIRED for the Review Console. Prisma reads this; the mariadb driver adapter
# (src/lib/prisma.ts and prisma.config.ts) connects with it. Put the REAL value
# in .env (gitignored) only; never commit it. URL-encode special characters in the
# password (e.g. ! -> %21, @ -> %40, # -> %23). Append ?ssl=true to validate the
# server certificate, or ?ssl=skip-verify if the managed host uses a cert outside
# the trust store.
#
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DBNAME

# ---------------------------------------------------------------------------
# Review Console (Phase 3, not used yet): commented placeholders only
# ---------------------------------------------------------------------------
# These will carry the Supabase project URL and public anon key for the future
# validator Review Console. No code reads them today. Leave them commented out
# and unset until Phase 3.

# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Review Console email notifications (admin -> reviewer status emails)
# ---------------------------------------------------------------------------
# Optional. When configured, an admin can email the reviewer who filed a finding
# from the finding-detail view (admin-in-the-loop; nothing is ever auto-sent).
# Leave these unset to disable email: the Console runs normally and the send
# action reports that SMTP is not configured. Put the REAL values in .env
# (gitignored) only; never commit them. This is the only part of the app that
# opens an outbound connection to an external server.
#
# SMTP_HOST=smtp.your-provider.example      # required to enable email
# SMTP_PORT=587                             # 587 = STARTTLS, 465 = implicit TLS
# SMTP_SECURE=false                         # true for port 465, false for 587
# SMTP_USER=                                # username, if the server requires auth
# SMTP_PASS=                                # app password or API key (NEVER commit)
# SMTP_FROM="MNM-Edu Review <reviews@your-domain.example>"  # required; From header
#
# SMTP_ENCRYPTION_KEY=                      # 32-byte key (base64 or hex). REQUIRED to save an
#                                           # SMTP password from /review/settings: it AES-256-GCM
#                                           # encrypts the password before storing it, so the DB
#                                           # (the database) never holds plaintext. The env SMTP_PASS
#                                           # fallback above stays plaintext (env-only) by design.
#                                           # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#                                           # Keep this ONLY in .env; if it is rotated/lost, re-enter
#                                           # the SMTP password once in /review/settings.
#
# The {{link}} placeholder in templates uses NEXTAUTH_URL (already required by the
# Review Console auth) as the base for the reviewer's own ticket link.

# ---------------------------------------------------------------------------
# Google Analytics (Phase 4a item 7): consent-gated GA4 measurement ID.
# ---------------------------------------------------------------------------
# This is the KILL-SWITCH for analytics. When NEXT_PUBLIC_GA_ID is UNSET (or empty),
# the public site is fully cookie-free: the consent banner does not render at all,
# the GA loader is not mounted, the "Cookie settings" footer link self-hides, and
# the CSP middleware does NOT broaden connect-src or img-src to allow Google hosts.
# Set this only AFTER the privacy policy is published and the cookie-banner UX is
# reviewed. Merging the consent feature without this env var keeps GA fully disabled.
#
# When set, the consent banner is rendered with default-deny (GA still does NOT load
# until the visitor presses Accept), and the privacy-respecting config below applies:
#   anonymize_ip: true, allow_google_signals: false, allow_ad_personalization_signals: false
#
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX     # GA4 measurement ID (G-... format)

# ---------------------------------------------------------------------------
# Server-side full-page snapshot (reviewer overlay "Capture page" button)
# ---------------------------------------------------------------------------
# Default OFF. The Infomaniak Managed Cloud Server has no Chromium, so the
# /api/snapshot route would crash and the reviewer overlay's "Capture page"
# button would be shown-and-broken. With this flag unset (or "0"), the API
# returns a clean 503 if hit AND the UI hides the button entirely; only the
# in-browser "Capture my current view" (getDisplayMedia) is offered, and that
# path stays fully working. Set to "1" only on a host where Chromium + the
# Playwright OS deps are installed (`npx playwright install --with-deps chromium`).
#
# NEXT_PUBLIC_ENABLE_SERVER_SNAPSHOT=1
